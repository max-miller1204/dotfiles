{{- $isWSL := and (eq .chezmoi.os "linux") (or (contains "microsoft" (lower .chezmoi.kernel.osrelease)) (contains "wsl" (lower .chezmoi.kernel.osrelease))) -}}
{{- $headless := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $headless = promptBoolOnce . "headless" "Is this machine headless/server-only (skip GUI desktop apps)" false -}}
{{- end -}}
{{- $nixSystem := "unsupported" -}}
{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.arch "amd64") -}}
{{-   $nixSystem = "x86_64-linux" -}}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") -}}
{{-   $nixSystem = "aarch64-darwin" -}}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "amd64") -}}
{{-   $nixSystem = "x86_64-darwin" -}}
{{- end -}}
{{- $homeManagerConfiguration := "unsupported" -}}
{{- if $isWSL -}}
{{-   $homeManagerConfiguration = "max@wsl" -}}
{{- else if and (eq .chezmoi.os "linux") $headless -}}
{{-   $homeManagerConfiguration = "max@linux-headless" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $homeManagerConfiguration = "max@linux-desktop" -}}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") -}}
{{-   $homeManagerConfiguration = "max@macos-aarch64" -}}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "amd64") -}}
{{-   $homeManagerConfiguration = "max@macos-x86_64" -}}
{{- end -}}
{{- $homeManagerOverride := env "DOTFILES_HM_CONFIGURATION" -}}
{{- if ne $homeManagerOverride "" -}}
{{-   $homeManagerConfiguration = $homeManagerOverride -}}
{{- end -}}
[data]
    isWSL = {{ if $isWSL }}true{{ else }}false{{ end }}
    # Headless/server-only profile: skip GUI desktop apps (and their configs).
    # Linux-only concept (the brev/GPU-server use case); on macOS it is always
    # false so macOS stays fully unaffected. Prompted once on a real interactive
    # `chezmoi init` and persisted; defaults false so a normal desktop is
    # unchanged. Non-interactive `chezmoi init` must pass --promptDefaults.
    # The prompt text has no trailing '?' on purpose: promptBoolOnce renders
    # its own question mark, so a literal one would double up.
    headless = {{ if $headless }}true{{ else }}false{{ end }}
    # Home Manager is the active owner of the Phase 2 CLI bundle. Set this to
    # false in chezmoi.toml for the emergency repository-rollback bypass.
    homeManagerEnabled = true
    nixSystem = "{{ $nixSystem }}"
    # DOTFILES_HM_CONFIGURATION is a CI/recovery override. The activation script
    # validates its output, username, home directory, and Nix system before use.
    homeManagerConfiguration = "{{ $homeManagerConfiguration }}"
    # The mise typescript prefix relative to $HOME, shared by the fish config's
    # NODE_PATH and the install script's resolution check (each prepends its own
    # shell's home) so the derived path can't drift between the two.
    tsNodeModulesRel = ".local/share/mise/installs/npm-typescript/latest/lib/node_modules"
    # Non-LSP Claude Code plugins (marketplace-qualified in the install script).
    # Installed/enabled by run_after_65-setup-claude-plugins.
    extraClaudePlugins = ["agent-sdk-dev", "skill-creator"]

# Single source of truth for the Claude Code LSP language set. Each entry couples
# the marketplace plugin (installed by run_after_65-setup-claude-plugins) to how
# that language's server is installed (consumed by
# run_onchange_after_50-install-lsp-servers and the lsp-upgrade fish function), so
# adding or removing an LSP language is a one-place edit here. The plugin list and
# the server-install list can no longer drift because both derive from this table.
#   method = "mise"   -> miseTools installed via `mise use -g`
#   method = "rustup" -> rustupComponent added to the active rust toolchain
#   method = "os"     -> OS package (aptPackage on Linux, brewFormula on macOS)
[[data.lspLanguages]]
    plugin = "rust-analyzer-lsp"
    method = "rustup"
    rustupComponent = "rust-analyzer"
    verifyBin = "rust-analyzer"
[[data.lspLanguages]]
    plugin = "pyright-lsp"
    method = "mise"
    miseTools = ["npm:pyright"]
    verifyBin = "pyright-langserver"
[[data.lspLanguages]]
    plugin = "typescript-lsp"
    method = "mise"
    miseTools = ["npm:typescript-language-server", "npm:typescript"]
    verifyBin = "typescript-language-server"
    verifyTsResolve = true
[[data.lspLanguages]]
    plugin = "gopls-lsp"
    method = "mise"
    miseTools = ["go:golang.org/x/tools/gopls"]
    verifyBin = "gopls"
[[data.lspLanguages]]
    plugin = "clangd-lsp"
    method = "os"
    verifyBin = "clangd"
    aptPackage = "clangd"
    brewFormula = "llvm"

{{- if $isWSL }}

# On WSL, use the Windows-side 1Password CLI so chezmoi's secret reads unlock
# via the Windows 1Password app (Windows Hello). Requires the Windows app with
# Settings → Developer → CLI integration enabled. The Linux op installed by
# the bootstrap remains available for runner scripts / manual op signin.
[onepassword]
    command = "op.exe"
{{- end }}
