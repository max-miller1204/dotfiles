{{- $isWSL := and (eq .chezmoi.os "linux") (or (contains "microsoft" (lower .chezmoi.kernel.osrelease)) (contains "wsl" (lower .chezmoi.kernel.osrelease))) -}}
[data]
    managedMcpNames = ["nixos", "playwright"]
    isWSL = {{ if $isWSL }}true{{ else }}false{{ end }}
    # Single source of truth for the mise-managed tools, consumed by both the
    # install scripts and the *-upgrade fish functions so the two never drift.
    lspMiseTools = ["npm:pyright", "npm:typescript-language-server", "npm:typescript", "go:golang.org/x/tools/gopls"]
    axiMiseTools = ["npm:gh-axi", "npm:chrome-devtools-axi", "npm:lavish-axi"]

{{- if $isWSL }}

# On WSL, use the Windows-side 1Password CLI so chezmoi's secret reads unlock
# via the Windows 1Password app (Windows Hello). Requires the Windows app with
# Settings → Developer → CLI integration enabled. The Linux op installed by
# the bootstrap remains available for runner scripts / manual op signin.
[onepassword]
    command = "op.exe"
{{- end }}
