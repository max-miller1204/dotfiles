#!/usr/bin/env bash
# Wire the axi agent hooks across ALL agents (Claude, Codex, OpenCode) using the
# supported `<tool> setup hooks` command. Each axi CLI shares axi-sdk-js, and a
# single `setup hooks` call idempotently writes, per tool:
#   - Claude : ~/.claude/settings.json   SessionStart hook  (bare `<tool>`, timeout 10)
#   - Codex  : ~/.codex/hooks.json        SessionStart hook  + ~/.codex/config.toml [features] hooks = true
#   - OpenCode: ~/.config/opencode/plugins/axi-<tool>.js     ambient-context plugin
#
# This is the single source of truth for axi hooks: each `<tool> setup hooks`
# owns its blocks in the agent config files, so nothing is vendored into
# dot_claude/settings.json. It is deliberately ordered after the axi CLIs are
# installed (run_once_before_10-install-packages) and after the agent config
# files are applied.
#
# This MUST be a plain `run_after_` script (runs on EVERY apply), not a
# `run_onchange_after_`. Claude's SessionStart axi hooks live only in the
# settings.json family, which chezmoi fully manages: every `chezmoi apply`
# rewrites ~/.claude/settings.json from source and strips anything a CLI
# appended. A `run_onchange_` keyed to this script's own hash would NOT re-fire
# after that strip (its hash is unchanged), so the Claude hooks would be
# silently lost. Running every apply re-asserts them. Codex's hooks.json and the
# OpenCode plugins are not chezmoi-managed, so re-running is a cheap no-op there.
# The resulting per-apply settings.json drift is intended - see README
# "Agent hooks (axi)" and AGENTS.md.
#
# axi tools: {{ .axiMiseTools | join " " }}
set -euo pipefail

log() { printf '\033[36m==>\033[0m %s\n' "$*"; }

# The axi CLIs are mise-managed; their shims live here and are not necessarily on
# PATH in a non-interactive `chezmoi apply`. Put the shim dir on PATH so each
# `<tool> setup hooks` resolves. Guard per-tool so a not-yet-installed CLI degrades
# to a skip instead of hard-failing the whole apply (self-heals on the next apply).
export PATH="$HOME/.local/share/mise/shims:$PATH"

{{- $axiBins := list -}}
{{- range .axiMiseTools -}}
{{-   $axiBins = append $axiBins (trimPrefix "npm:" .) -}}
{{- end }}
for tool in {{ $axiBins | join " " }}; do
    if command -v "$tool" >/dev/null 2>&1; then
        log "Wiring agent hooks: $tool setup hooks"
        "$tool" setup hooks || log "warn: setup hooks failed for $tool (retries next apply)"
    else
        log "skip: $tool not on PATH yet (will wire on next apply)"
    fi
done
