#!/usr/bin/env bash
# Activate the selected standalone Home Manager generation before chezmoi
# changes any managed target files. This script intentionally runs on every
# apply so a module or lock-file change cannot be missed.
{{ template "lib-log.sh" . }}

{{ template "lib-resolve.sh" . }}

{{ template "lib-lsp-verify.sh" . }}
LSP_SPECS=(
{{ template "lib-lsp-specs" . }}
)
{{- $enabled := true }}
{{- if hasKey . "homeManagerEnabled" }}
{{-   $enabled = get . "homeManagerEnabled" }}
{{- end }}
{{- $configuration := "unsupported" }}
{{- if .isWSL }}
{{-   $configuration = "max@wsl" }}
{{- else if and (eq .chezmoi.os "linux") (get . "headless") }}
{{-   $configuration = "max@linux-headless" }}
{{- else if eq .chezmoi.os "linux" }}
{{-   $configuration = "max@linux-desktop" }}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
{{-   $configuration = "max@macos-aarch64" }}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "amd64") }}
{{-   $configuration = "max@macos-x86_64" }}
{{- end }}
{{- if hasKey . "homeManagerConfiguration" }}
{{-   $configuration = get . "homeManagerConfiguration" }}
{{- end }}
{{- $override := env "DOTFILES_HM_CONFIGURATION" }}
{{- if ne $override "" }}
{{-   $configuration = $override }}
{{- end }}
{{- $nixSystem := "unsupported" }}
{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.arch "amd64") }}
{{-   $nixSystem = "x86_64-linux" }}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
{{-   $nixSystem = "aarch64-darwin" }}
{{- else if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "amd64") }}
{{-   $nixSystem = "x86_64-darwin" }}
{{- end }}
{{- if hasKey . "nixSystem" }}
{{-   $nixSystem = get . "nixSystem" }}
{{- end }}

{{ if not $enabled -}}
log "Home Manager activation disabled by homeManagerEnabled=false"
exit 0
{{ end -}}

CHEZMOI_SOURCE={{ .chezmoi.sourceDir | quote }}
HOME_MANAGER_CONFIGURATION={{ $configuration | quote }}
EXPECTED_NIX_SYSTEM={{ $nixSystem | quote }}
FLAKE="path:$CHEZMOI_SOURCE/nix"

case "$HOME_MANAGER_CONFIGURATION" in
    max@linux-desktop|max@linux-headless|max@wsl|max@macos-aarch64|max@macos-x86_64|\
    ci@linux-desktop|ci@linux-headless|ci@wsl|ci@macos-aarch64|ci@macos-x86_64)
        ;;
    *)
        printf 'Invalid Home Manager configuration: %s\n' \
            "$HOME_MANAGER_CONFIGURATION" >&2
        printf '%s\n' \
            'Set DOTFILES_HM_CONFIGURATION to one of the flake outputs in nix/flake.nix.' >&2
        exit 1
        ;;
esac

if [[ "$EXPECTED_NIX_SYSTEM" == "unsupported" ]]; then
    printf 'Home Manager does not support this platform: %s/%s\n' \
        {{ .chezmoi.os | quote }} {{ .chezmoi.arch | quote }} >&2
    exit 1
fi

NIX_BIN="$(resolve_nix)"
if [[ -z "$NIX_BIN" ]]; then
{{- if eq .chezmoi.os "darwin" }}
    printf '%s\n' \
        'Nix is required before Home Manager activation on macOS.' \
        'Install Determinate Nix with the Determinate.pkg, open a new shell, and rerun chezmoi apply.' >&2
{{- else }}
    printf '%s\n' \
        'Nix installation did not complete. Fix Determinate Nix and rerun chezmoi apply.' >&2
{{- end }}
    exit 1
fi

if [[ ! -f "$CHEZMOI_SOURCE/nix/flake.nix" || ! -f "$CHEZMOI_SOURCE/nix/flake.lock" ]]; then
    printf 'Home Manager flake is incomplete under %s/nix\n' "$CHEZMOI_SOURCE" >&2
    exit 1
fi

configuration_attr="$FLAKE#homeConfigurations.\"$HOME_MANAGER_CONFIGURATION\".config"
configured_user="$($NIX_BIN eval --raw --no-write-lock-file \
    "$configuration_attr.home.username")"
configured_home="$($NIX_BIN eval --raw --no-write-lock-file \
    "$configuration_attr.home.homeDirectory")"
configured_system="$($NIX_BIN eval --raw --no-write-lock-file \
    "$configuration_attr.nixpkgs.system")"
actual_user="$(id -un)"

if [[ "$configured_user" != "$actual_user" ]]; then
    printf 'Home Manager output %s is for user %s, not %s.\n' \
        "$HOME_MANAGER_CONFIGURATION" "$configured_user" "$actual_user" >&2
    exit 1
fi
if [[ "$configured_home" != "$HOME" ]]; then
    printf 'Home Manager output %s is for home %s, not %s.\n' \
        "$HOME_MANAGER_CONFIGURATION" "$configured_home" "$HOME" >&2
    exit 1
fi
if [[ "$configured_system" != "$EXPECTED_NIX_SYSTEM" ]]; then
    printf 'Home Manager output %s is for %s, not %s.\n' \
        "$HOME_MANAGER_CONFIGURATION" "$configured_system" "$EXPECTED_NIX_SYSTEM" >&2
    exit 1
fi

remove_new_profile() {
    local active_link="$1" generation_prefix="$2" profiles_dir
    profiles_dir="$(dirname "$active_link")"
    rm -f "$active_link"
    if [[ -d "$profiles_dir" ]]; then
        find "$profiles_dir" -maxdepth 1 -type l \
            -name "$generation_prefix-*-link" -delete
    fi
}

nix_state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/nix/profiles"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
profile="$nix_state_dir/home-manager"
package_profile="$nix_state_dir/profile"
before_switch_file="$state_dir/home-manager-before-switch"
previous_generation_file="$state_dir/home-manager-previous-generation"
umask 077
mkdir -p "$nix_state_dir" "$state_dir"
if [[ -e "$profile" || -L "$profile" ]]; then
    before_generation="$(resolve_link "$profile")"
else
    before_generation='<none>'
fi
if [[ -e "$package_profile" || -L "$package_profile" ]]; then
    before_package_generation="$(resolve_link "$package_profile")"
else
    before_package_generation='<none>'
fi
printf '%s\n' "$before_generation" >"$before_switch_file"

log "Activating Home Manager configuration $HOME_MANAGER_CONFIGURATION"
set +e
"$NIX_BIN" run --no-write-lock-file "$FLAKE#home-manager" -- \
    switch --flake "$FLAKE#$HOME_MANAGER_CONFIGURATION"
switch_status=$?
if [[ "$switch_status" -eq 0 ]]; then
    verify_home_manager_lsp_servers \
        "$package_profile/bin" "${LSP_SPECS[@]}"
    switch_status=$?
fi
set -e

if [[ "$switch_status" -ne 0 ]]; then
    rollback_ok=true
    if [[ "$before_generation" != '<none>' ]]; then
        log "Restoring Home Manager generation $before_generation"
        if [[ "$(resolve_link "$profile")" != "$before_generation" ]]; then
            if ! "$NIX_BIN" profile rollback --profile "$profile"; then
                rollback_ok=false
            elif [[ "$(resolve_link "$profile")" != "$before_generation" ]]; then
                rollback_ok=false
            fi
        fi
        if [[ "$rollback_ok" == true ]] \
            && ! "$before_generation/activate"; then
            rollback_ok=false
        fi
    else
        log "Removing the failed first Home Manager generation"
        remove_new_profile "$profile" home-manager
        if [[ "$before_package_generation" == '<none>' ]]; then
            remove_new_profile "$package_profile" profile
        elif [[ -e "$package_profile" || -L "$package_profile" ]] \
            && [[ "$(resolve_link "$package_profile")" \
                != "$before_package_generation" ]]; then
            if ! "$NIX_BIN" profile rollback --profile "$package_profile"; then
                rollback_ok=false
            elif [[ "$(resolve_link "$package_profile")" \
                != "$before_package_generation" ]]; then
                rollback_ok=false
            fi
        fi
    fi
    if [[ "$rollback_ok" != true ]]; then
        printf '%s\n' \
            'Home Manager activation failed and automatic rollback also failed.' \
            "Restore $before_generation manually before retrying." >&2
    fi
    exit "$switch_status"
fi

after_generation="$(resolve_link "$profile")"
printf '%s\n' "$HOME_MANAGER_CONFIGURATION" \
    >"$state_dir/home-manager-configuration"
if [[ "$after_generation" != "$before_generation" ]]; then
    printf '%s\n' "$before_generation" >"$previous_generation_file"
elif [[ ! -e "$previous_generation_file" ]]; then
    printf '%s\n' '<none>' >"$previous_generation_file"
fi
