#!/usr/bin/env bash
# Install LazyVim starter if no nvim config is present.
{{ template "lib-log.sh" . }}

if [[ ! -d "$HOME/.config/nvim" ]]; then
    log "Cloning LazyVim starter into ~/.config/nvim"
    git clone https://github.com/LazyVim/starter "$HOME/.config/nvim"
    rm -rf "$HOME/.config/nvim/.git"
fi
