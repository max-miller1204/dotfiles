#!/usr/bin/env bash
# Install every CLI tool and desktop app these dotfiles expect. Runs exactly once
# per unique content hash (rerun only if this script changes).
#
# The package set is data, not code: .chezmoidata/packages.yaml describes each
# package once with its per-OS install method, and the single loop below walks
# `.packages` and dispatches each entry to the matching install_* helper in
# .chezmoitemplates/lib-install.sh by OS + method. Adding a tool is a one-line
# manifest edit. GUI packages are skipped when headless or on WSL (Windows-native
# versions are used there). Everything after the loop (mise toolchains, Nix,
# coding agents, login shell) is not part of the manifest and is unchanged.
{{ template "lib-log.sh" . }}

{{ template "lib-resolve.sh" . }}

{{ template "lib-apt.sh" . }}

{{ template "lib-install.sh" . }}
{{- /* Headless/server-only profile skips GUI apps just like WSL. Defensive
       `get` returns a falsy empty on an existing machine whose persisted config
       predates this key, so an absent `headless` collapses to isWSL-only. */ -}}
{{- $headlessVal := (get . "headless") }}

{{- if eq .chezmoi.os "darwin" }}

# ---- macOS prep: Homebrew -----------------------------------------
if ! command -v brew >/dev/null 2>&1; then
    log "Installing Homebrew"
    NONINTERACTIVE=1 /bin/bash -c \
        "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

{{- else if eq .chezmoi.os "linux" }}

# ---- Ubuntu / Debian prep -----------------------------------------
if ! command -v apt-get >/dev/null 2>&1; then
    echo "This bootstrap only supports apt-based Linux (Ubuntu/Debian)." >&2
    exit 1
fi

log "Updating apt"
sudo apt-get update -y
{{- if (or .isWSL $headlessVal) }}
log "headless/WSL - skipping GUI desktop apps"
{{- end }}
{{- end }}

# ---- ~/.local/bin ---------------------------------------------------
# Every OS, before the package loop. Both lines are load-bearing, for different
# installers:
#   prepend_path - treehouse (`grep -qx` over $PATH) and no-mistakes (`case ":$PATH:"`,
#                  for its symlink dir; its binary always lands in ~/.no-mistakes/bin)
#                  choose their target dir by $PATH MEMBERSHIP alone, and otherwise
#                  fall back to a sudo install into /usr/local/bin. A non-interactive
#                  `chezmoi apply` never inherits that PATH entry, and under
#                  `set -euo pipefail` a failed sudo aborts the whole bootstrap.
#   mkdir        - pfetch curls straight into "$HOME/.local/bin/pfetch" (Linux; brew
#                  on macOS), which fails if the dir is absent. It also keeps
#                  treehouse off that same sudo branch: treehouse guards its plain
#                  `mv` on `[ -w "$INSTALL_DIR" ]`, which a nonexistent dir fails, so
#                  PATH membership without the dir yields a root-owned ~/.local/bin.
# mise, brev and herdr need neither line - each writes to ~/.local/bin unconditionally
# and creates it itself. Both lines also make the loop's `command -v <bin>` guards see
# what a previous apply installed there.
mkdir -p "$HOME/.local/bin"
prepend_path "$HOME/.local/bin"

# ---- Package manifest (.chezmoidata/packages.yaml) ----------------
# One loop over every package; each dispatches to its install_* helper by OS +
# method, taking the OS-specific key when present and falling back to the shared
# `any` key otherwise. GUI packages are skipped when headless or on WSL.
{{- $supportedOS := or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") }}
{{- range $pkg := .packages }}
{{-   $os := dict }}
{{-   $hasOS := false }}
{{-   if and (eq $.chezmoi.os "darwin") (hasKey $pkg "darwin") }}
{{-     $os = get $pkg "darwin" }}
{{-     $hasOS = true }}
{{-   else if and (eq $.chezmoi.os "linux") (hasKey $pkg "linux") }}
{{-     $os = get $pkg "linux" }}
{{-     $hasOS = true }}
{{-   else if and $supportedOS (hasKey $pkg "any") }}
{{-     $os = get $pkg "any" }}
{{-     $hasOS = true }}
{{-   end }}
{{-   if and $hasOS (not (and (get $pkg "gui") (or $.isWSL $headlessVal))) }}
{{-     if hasKey $os "brew" }}
install_brew "{{ $os.brew }}"{{ if get $os "tolerant" }} || true{{ end }}
{{-     else if hasKey $os "cask" }}
install_cask "{{ $os.cask }}"
{{-     else if hasKey $os "apt" }}
install_apt "{{ get $pkg "bin" }}" "{{ $os.apt }}"{{ if hasKey $os "ppa" }} "{{ $os.ppa }}"{{ end }}
{{-     else if hasKey $os "aptrepo" }}
{{-       $repo := index $.aptrepos (get $os "aptrepo") }}
if ! command -v {{ get $pkg "bin" }} >/dev/null 2>&1; then
{{-       if hasKey $repo "debsig" }}
    install_debsig "{{ $repo.debsig.policy_id }}" "{{ $repo.debsig.pol_url }}" "{{ $repo.debsig.key_url }}"
{{-       end }}
    install_aptrepo "{{ $repo.label }}" \
        "{{ $repo.keyring }}" \
        "{{ $repo.key_url }}" \
        "{{ $repo.repo_line }}" \
        "{{ $repo.list_path }}" \
        "{{ $repo.package }}"
fi
{{-     else if hasKey $os "flatpak" }}
install_flatpak "{{ $os.flatpak }}"
{{-     else if hasKey $os "deburl" }}
if ! command -v {{ get $pkg "bin" }} >/dev/null 2>&1; then
    DEB_URL="{{ $os.deburl }}"
    install_deburl "{{ get $pkg "bin" }}" "$DEB_URL"
fi
{{-     else if hasKey $os "script" }}
{{-       if hasKey $os "dpkg" }}
if ! dpkg -s {{ $os.dpkg }} >/dev/null 2>&1; then
    log "Installing {{ $pkg.name }}"
    {{ $os.script }}
fi
{{-       else if hasKey $os "altpath" }}
if ! command -v {{ get $pkg "bin" }} >/dev/null 2>&1 && [[ ! -x "{{ $os.altpath }}" ]]; then
    log "Installing {{ $pkg.name }}"
    {{ $os.script }}
fi
{{-       else }}
if ! command -v {{ get $pkg "bin" }} >/dev/null 2>&1; then
    log "Installing {{ $pkg.name }}"
    {{ $os.script }}
fi
{{-       end }}
{{-     else if hasKey $os "mise" }}
install_mise "{{ get $pkg "bin" }}" "{{ $os.mise }}"
{{-     end }}
{{-   end }}
{{- end }}

# ---- mise toolchains (node needed for npx / MCP runners) ---------
MISE_BIN="$(resolve_mise)"
if [[ -n "$MISE_BIN" ]]; then
    log "Installing toolchains via mise (node, python, rust, go, fzf, bun, neovim)"
    "$MISE_BIN" use -g \
        node@lts python@latest rust@latest go@latest \
        fzf@latest bun@latest neovim@latest uv@latest

    # Agent "axi" CLIs - ergonomic wrappers the coding agents drive via their
    # SessionStart hooks and tools (gh, browser, lavish review, tasks surfaces).
    # Installed as mise-managed npm tools so they survive node upgrades.
    log "Installing agent axi CLIs (gh-axi, chrome-devtools-axi, lavish-axi, tasks-axi)"
    "$MISE_BIN" use -g {{ .axiMiseTools | join " " }}
fi

{{- if eq .chezmoi.os "linux" }}
# ---- Nix (Determinate installer) - macOS uses the .pkg manually ---
# Run the installer as root with HOME and XDG_CONFIG_HOME pinned to root's own:
# the installer's shell self-test launches root-run INTERACTIVE user shells
# (fish -ic), and fish creates its config dir at $XDG_CONFIG_HOME/fish on
# startup. On hosts whose environment leaks the invoking user's paths into
# root's env (GitHub runners put XDG_CONFIG_HOME=$HOME/.config in
# /etc/environment; some setups env_keep it through sudo), that self-test
# created a root-owned ~/.config/fish in the USER's home, which then broke
# chezmoi's own write of the fish config. Pinning both variables makes the
# self-test write under /root regardless of the host's sudo/env quirks;
# sudo still exposes SUDO_USER so the installer can see the real user.
if ! command -v nix >/dev/null 2>&1 && [[ ! -d /nix ]]; then
    log "Installing Nix via Determinate installer"
    curl -fsSL https://install.determinate.systems/nix | sudo HOME=/root XDG_CONFIG_HOME=/root/.config sh -s -- install --no-confirm
fi
{{- end }}

# ---- Coding agents (native installers, not npm) -------------------
if ! command -v claude >/dev/null 2>&1 && [[ ! -x "$HOME/.local/bin/claude" ]]; then
    log "Installing Claude Code via official installer"
    curl -fsSL https://claude.ai/install.sh | bash
fi

if ! command -v codex >/dev/null 2>&1 && [[ ! -x "$HOME/.local/bin/codex" ]]; then
    log "Installing Codex CLI via official installer"
    curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh
fi

# OpenCode installs to ~/.opencode/bin via its official installer; --no-modify-path
# stops it editing shell rc (the chezmoi-managed fish config puts it on PATH instead).
if ! command -v opencode >/dev/null 2>&1 && [[ ! -x "$HOME/.opencode/bin/opencode" ]]; then
    log "Installing OpenCode via official installer"
    curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path
fi

# ---- Make fish a login shell --------------------------------------
FISH_PATH="$(command -v fish || true)"
if [[ -n "$FISH_PATH" ]]; then
    if ! grep -qx "$FISH_PATH" /etc/shells 2>/dev/null; then
        log "Adding $FISH_PATH to /etc/shells"
        echo "$FISH_PATH" | sudo tee -a /etc/shells >/dev/null
    fi
    if [[ "${SHELL:-}" != "$FISH_PATH" ]]; then
        log "Setting fish as default shell (you may be prompted for your password)"
        chsh -s "$FISH_PATH" || true
    fi
fi
