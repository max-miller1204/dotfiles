#!/usr/bin/env bash
# Install every CLI tool these dotfiles expect. Runs exactly once per
# unique content hash (rerun only if this script changes).
set -euo pipefail

log() { printf '\033[36m==>\033[0m %s\n' "$*"; }

{{- if eq .chezmoi.os "darwin" }}

# ---- macOS --------------------------------------------------------
if ! command -v brew >/dev/null 2>&1; then
    log "Installing Homebrew"
    NONINTERACTIVE=1 /bin/bash -c \
        "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

log "Installing packages via Homebrew"
brew install \
    fish git tmux eza fzf zoxide starship bat fd ripgrep jq \
    atuin mise pfetch gh gum age

brew install --cask ghostty || true
brew install --cask aerospace || true
brew install --cask karabiner-elements || true
brew install --cask raycast || true
brew install --cask discord || true
brew install --cask zed || true
brew install --cask neovide-app || true
brew install --cask voquill/voquill/voquill-desktop || true
brew install --cask zoom || true
brew install --cask anki || true
brew install --cask obsidian || true
brew install --cask spotify || true
brew install --cask balenaetcher || true
brew install --cask macdown-3000 || true
brew install --cask pearcleaner || true
brew install --cask font-jetbrains-mono-nerd-font || true

{{- else if eq .chezmoi.os "linux" }}

# ---- Ubuntu / Debian ----------------------------------------------
if ! command -v apt-get >/dev/null 2>&1; then
    echo "This bootstrap only supports apt-based Linux (Ubuntu/Debian)." >&2
    exit 1
fi

log "Updating apt"
sudo apt-get update -y

log "Installing base apt packages"
sudo apt-get install -y \
    fish git tmux zoxide bat ripgrep jq curl wget age \
    fd-find ca-certificates gnupg build-essential \
    software-properties-common zenity

# Ubuntu names them batcat/fdfind — symlink to the canonical names.
mkdir -p "$HOME/.local/bin"
if command -v batcat >/dev/null 2>&1 && ! command -v bat >/dev/null 2>&1; then
    ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
fi
if command -v fdfind >/dev/null 2>&1 && ! command -v fd >/dev/null 2>&1; then
    ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
fi

# eza — not in default apt repos on older Ubuntu.
if ! command -v eza >/dev/null 2>&1; then
    log "Installing eza from its apt repo"
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
        | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
        | sudo tee /etc/apt/sources.list.d/gierens.list >/dev/null
    sudo apt-get update -y
    sudo apt-get install -y eza
fi

# starship
if ! command -v starship >/dev/null 2>&1; then
    log "Installing starship"
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# atuin
if ! command -v atuin >/dev/null 2>&1 && [[ ! -x "$HOME/.atuin/bin/atuin" ]]; then
    log "Installing atuin"
    curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh
fi

# mise
if ! command -v mise >/dev/null 2>&1 && [[ ! -x "$HOME/.local/bin/mise" ]]; then
    log "Installing mise"
    curl https://mise.run | sh
fi

# gh (GitHub CLI) — used by the gitconfig credential helper
if ! command -v gh >/dev/null 2>&1; then
    log "Installing gh"
    sudo mkdir -p -m 755 /etc/apt/keyrings
    wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
    sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
    sudo apt-get update -y
    sudo apt-get install -y gh
fi

# pfetch — tiny system info fetcher printed at fish startup
if ! command -v pfetch >/dev/null 2>&1; then
    log "Installing pfetch"
    curl -fsSL https://raw.githubusercontent.com/dylanaraps/pfetch/master/pfetch \
        -o "$HOME/.local/bin/pfetch"
    chmod +x "$HOME/.local/bin/pfetch"
fi

# gum — used by the git worktree fish functions for confirmations
if ! command -v gum >/dev/null 2>&1; then
    log "Installing gum"
    sudo mkdir -p -m 755 /etc/apt/keyrings
    wget -qO- https://repo.charm.sh/apt/gpg.key \
        | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
    echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" \
        | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null
    sudo apt-get update -y
    sudo apt-get install -y gum
fi

# ghostty — PPA has a current release; not in default apt repos
if ! command -v ghostty >/dev/null 2>&1; then
    log "Installing ghostty from mkasberg/ghostty-ubuntu"
    sudo add-apt-repository -y ppa:mkasberg/ghostty-ubuntu
    sudo apt-get update -y
    sudo apt-get install -y ghostty
fi

# discord — no official apt repo; grab the latest .deb and let apt resolve deps
if ! command -v discord >/dev/null 2>&1; then
    log "Installing discord from the official .deb"
    DISCORD_DEB="$(mktemp --suffix=.deb)"
    curl -fsSL -o "$DISCORD_DEB" "https://discord.com/api/download?platform=linux&format=deb"
    sudo apt-get install -y "$DISCORD_DEB"
    rm -f "$DISCORD_DEB"
fi

# voquill — vendor apt repo + package install. The installed binary is
# voquill-desktop, so guard on the dpkg package state rather than a command name.
if ! dpkg -s voquill-desktop >/dev/null 2>&1; then
    log "Installing voquill"
    curl -fsSL https://voquill.github.io/apt/install.sh | bash
fi

# zed — official installer drops the binary in ~/.local/bin (no apt repo)
if ! command -v zed >/dev/null 2>&1 && [[ ! -x "$HOME/.local/bin/zed" ]]; then
    log "Installing zed via the official installer"
    curl -f https://zed.dev/install.sh | sh
fi

# zoom — no apt repo; grab the latest .deb and let apt resolve deps
if ! command -v zoom >/dev/null 2>&1; then
    log "Installing zoom from the official .deb"
    ZOOM_DEB="$(mktemp --suffix=.deb)"
    curl -fsSL -o "$ZOOM_DEB" "https://zoom.us/client/latest/zoom_amd64.deb"
    sudo apt-get install -y "$ZOOM_DEB"
    rm -f "$ZOOM_DEB"
fi

# flatpak + flathub — needed for anki and spotify
if ! command -v flatpak >/dev/null 2>&1; then
    log "Installing flatpak"
    sudo apt-get install -y flatpak
fi
sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

# anki — flatpak from flathub
if ! flatpak info net.ankiweb.Anki >/dev/null 2>&1; then
    log "Installing anki via flatpak"
    sudo flatpak install -y flathub net.ankiweb.Anki
fi

# spotify — flatpak from flathub
if ! flatpak info com.spotify.Client >/dev/null 2>&1; then
    log "Installing spotify via flatpak"
    sudo flatpak install -y flathub com.spotify.Client
fi

# obsidian — no apt repo; fetch latest .deb from the GitHub releases
if ! command -v obsidian >/dev/null 2>&1; then
    log "Installing obsidian from the latest GitHub .deb"
    OBSIDIAN_DEB_URL="$(curl -fsSL https://api.github.com/repos/obsidianmd/obsidian-releases/releases/latest \
        | jq -r '.assets[] | select(.name | endswith("_amd64.deb")) | .browser_download_url' | head -n1)"
    OBSIDIAN_DEB="$(mktemp --suffix=.deb)"
    curl -fsSL -o "$OBSIDIAN_DEB" "$OBSIDIAN_DEB_URL"
    sudo apt-get install -y "$OBSIDIAN_DEB"
    rm -f "$OBSIDIAN_DEB"
fi

{{- end }}

# ---- mise toolchains (node needed for npx / MCP runners) ---------
MISE_BIN=""
if command -v mise >/dev/null 2>&1; then
    MISE_BIN="$(command -v mise)"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
    MISE_BIN="$HOME/.local/bin/mise"
fi
if [[ -n "$MISE_BIN" ]]; then
    log "Installing toolchains via mise (node, python, rust, go, fzf, bun, neovim)"
    "$MISE_BIN" use -g \
        node@lts python@latest rust@latest go@latest \
        fzf@latest bun@latest neovim@latest uv@latest
fi

# ---- Nix (Determinate installer) ----------------------------------
if ! command -v nix >/dev/null 2>&1 && [[ ! -d /nix ]]; then
    log "Installing Nix via Determinate installer"
    curl -fsSL https://install.determinate.systems/nix | sh -s -- install --no-confirm
fi

# ---- Claude Code (native installer, not npm) ----------------------
if ! command -v claude >/dev/null 2>&1 && [[ ! -x "$HOME/.local/bin/claude" ]]; then
    log "Installing Claude Code via official installer"
    curl -fsSL https://claude.ai/install.sh | bash
fi

# ---- Secrets directory (MCP runners read keys from here) ----------
log "Preparing ~/.config/secrets (mode 700)"
mkdir -p "$HOME/.config/secrets"
chmod 700 "$HOME/.config/secrets"

# ---- Make fish a login shell --------------------------------------
FISH_PATH="$(command -v fish || true)"
if [[ -n "$FISH_PATH" ]]; then
    if ! grep -qx "$FISH_PATH" /etc/shells 2>/dev/null; then
        log "Adding $FISH_PATH to /etc/shells"
        echo "$FISH_PATH" | sudo tee -a /etc/shells >/dev/null
    fi
    if [[ "${SHELL:-}" != "$FISH_PATH" ]]; then
        log "Setting fish as default shell (you may be prompted for your password)"
        chsh -s "$FISH_PATH" || true
    fi
fi
