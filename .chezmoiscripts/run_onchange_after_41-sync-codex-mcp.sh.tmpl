#!/usr/bin/env bash
# Sync managed [mcp_servers.*] sections into ~/.codex/config.toml.
# Strips sections named in the staging TOML, then appends the staging TOML.
#
# staging hash: {{ include "dot_config/codex/mcp-servers.toml.tmpl" | sha256sum }} {{ include ".chezmoidata/mcp.yaml" | sha256sum }}

set -euo pipefail

STAGING_SOURCE="${HOME}/.config/codex/mcp-servers.toml"
{{ template "lib-codex-sync.sh" . }}

# Manage exactly the server names declared in the staging file, so entries
# added by other tools (e.g. Codex's own plugin registry) are never touched.
# Removing a server from staging therefore needs a one-time manual cleanup
# of its leftover section in ~/.codex/config.toml.
MANAGED_RE="$(sed -nE 's/^\[mcp_servers\.([A-Za-z0-9_-]+)\]$/\1/p' "$STAGING_SOURCE" | paste -sd'|' -)"
[ -n "$MANAGED_RE" ] || { echo "no [mcp_servers.*] sections in $STAGING_SOURCE" >&2; exit 1; }

# Build the regex inside awk — backslashes passed via -v get escape-processed
# and the anchors/brackets would be silently corrupted into a char class.
awk -v names="$MANAGED_RE" '
  BEGIN { re = "^\\[mcp_servers\\.(" names ")\\]$"; skip = 0 }
  $0 ~ re { skip = 1; next }
  /^\[/   { skip = 0 }
  !skip   { print }
' "$CODEX_CONFIG" > "$CODEX_CONFIG.tmp"

# Ensure a blank line between existing content and our appended sections.
if [ -s "$CODEX_CONFIG.tmp" ] && [ -n "$(tail -c1 "$CODEX_CONFIG.tmp")" ]; then
  printf '\n' >> "$CODEX_CONFIG.tmp"
fi

cat "$STAGING_SOURCE" >> "$CODEX_CONFIG.tmp"
mv "$CODEX_CONFIG.tmp" "$CODEX_CONFIG"

echo "Synced MCP servers into ~/.codex/config.toml"
