#!/usr/bin/env bash
{{ $rustToolchain := (get . "rustToolchain" | default "stable") }}
# Install the language servers the enabled Claude Code LSP plugins expect.
# The single source of truth for the LSP language set is `lspLanguages` in
# .chezmoi.toml.tmpl. Servers may come from mise, Nix, rustup, or the OS package
# manager; run_after_65 installs and enables the matching plugins from the same
# table so the two lists cannot drift.
{{ template "lib-log.sh" . }}

{{ template "lib-resolve.sh" . }}

profile="${XDG_STATE_HOME:-$HOME/.local/state}/nix/profiles/dotfiles"
prepend_path "$profile/bin" "$HOME/.local/bin" "${CARGO_HOME:-$HOME/.cargo}/bin"
unset RUSTUP_TOOLCHAIN

MISE_BIN="$(resolve_mise)"
if [[ -z "$MISE_BIN" ]]; then
    echo "mise not found; cannot install the remaining mise-backed LSP servers" >&2
    exit 1
fi

# Initialize the fnm-managed default Node in this non-interactive shell. The
# TypeScript verification below must not depend on a stale mise Node declaration.
if [[ ! -x "$profile/bin/fnm" ]]; then
    echo "fnm is missing from the dedicated Nix profile" >&2
    exit 1
fi
eval "$("$profile/bin/fnm" env --shell bash)"

# ---- transitional mise-managed npm servers -----------------------
{{- $miseTools := list -}}
{{- range .lspLanguages -}}
{{-   if eq .method "mise" -}}
{{-     range .miseTools -}}
{{-       $miseTools = append $miseTools . -}}
{{-     end -}}
{{-   end -}}
{{- end }}
{{- if $miseTools }}
log "Installing mise-backed LSP servers ({{ $miseTools | join " " }})"
"$MISE_BIN" use -g {{ $miseTools | join " " }}
{{- end }}

# ---- rustup component servers (rust-analyzer) --------------------
{{- range .lspLanguages }}
{{-   if eq .method "rustup" }}
RUSTUP_BIN="$(resolve_rustup rustup)"
if [[ -z "$RUSTUP_BIN" ]]; then
    echo "rustup not found; cannot install {{ .rustupComponent }}" >&2
    exit 1
fi
log "Ensuring {{ .rustupComponent }} (rustup component for {{ .plugin }})"
"$RUSTUP_BIN" component add --toolchain "{{ $rustToolchain }}" {{ .rustupComponent }}
{{-   end }}
{{- end }}

# ---- OS-package servers (clangd) ---------------------------------
{{- range .lspLanguages }}
{{-   if eq .method "os" }}
{{- if eq $.chezmoi.os "darwin" }}
if ! command -v {{ .verifyBin }} >/dev/null 2>&1 && [[ ! -x "$HOME/.local/bin/{{ .verifyBin }}" ]]; then
    log "Installing {{ .verifyBin }} via Homebrew {{ .brewFormula }} (for {{ .plugin }})"
    brew install {{ .brewFormula }}
    # {{ .brewFormula }} is keg-only, so expose its server through ~/.local/bin.
    # TODO(macos): confirm on a Mac - this branch is untested from Linux.
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(brew --prefix {{ .brewFormula }})/bin/{{ .verifyBin }}" "$HOME/.local/bin/{{ .verifyBin }}"
fi
{{- else if eq $.chezmoi.os "linux" }}
if ! command -v {{ .verifyBin }} >/dev/null 2>&1; then
    log "Installing {{ .verifyBin }} via apt (for {{ .plugin }})"
    sudo apt-get install -y {{ .aptPackage }}
fi
{{- end }}
{{-   end }}
{{- end }}

# ---- verify every enabled server resolves and runs ---------------
log "Verifying language servers"
fail=0
{{- $miseVerify := list -}}
{{- range .lspLanguages -}}
{{-   if and (eq .method "mise") .verifyBin -}}
{{-     $miseVerify = append $miseVerify .verifyBin -}}
{{-   end -}}
{{- end }}
for bin in {{ $miseVerify | join " " }}; do
    if ! "$MISE_BIN" which "$bin" >/dev/null 2>&1; then
        echo "MISSING (mise): $bin" >&2; fail=1
    fi
done
{{- range .lspLanguages }}
{{-   if get . "verifyTsResolve" }}
# {{ .plugin }} resolves TypeScript at runtime across mise's isolated npm
# prefixes. NODE_PATH remains transitional until the TypeScript tools move.
TS_MODULES="$HOME/{{ $.tsNodeModulesRel }}"
NODE_BIN="$(command -v node 2>/dev/null || true)"
if [[ -z "$NODE_BIN" ]] || ! NODE_PATH="$TS_MODULES" "$NODE_BIN" -e "require.resolve('typescript')" >/dev/null 2>&1; then
    echo "MISSING: typescript not resolvable by {{ .verifyBin }}" >&2; fail=1
fi
{{-   end }}
{{- end }}
{{- range .lspLanguages }}
{{-   if eq .method "nix" }}
if [[ ! -x "$profile/bin/{{ .verifyBin }}" ]] || ! "$profile/bin/{{ .verifyBin }}" version >/dev/null 2>&1; then
    echo "MISSING (Nix profile): {{ .verifyBin }}" >&2; fail=1
fi
{{-   end }}
{{-   if eq .method "rustup" }}
RA_BIN="$(resolve_rustup {{ .verifyBin }})"
if [[ -z "$RA_BIN" ]] || ! "$RA_BIN" --version >/dev/null 2>&1; then
    echo "MISSING: {{ .verifyBin }}" >&2; fail=1
fi
{{-   end }}
{{-   if eq .method "os" }}
if ! { command -v {{ .verifyBin }} >/dev/null 2>&1 || [[ -x /usr/bin/{{ .verifyBin }} ]] || [[ -x "$HOME/.local/bin/{{ .verifyBin }}" ]]; }; then
    echo "MISSING: {{ .verifyBin }}" >&2; fail=1
fi
{{-   end }}
{{- end }}
if [[ "$fail" -ne 0 ]]; then
    echo "One or more LSP servers failed to install" >&2
    exit 1
fi
log "All LSP servers present"
