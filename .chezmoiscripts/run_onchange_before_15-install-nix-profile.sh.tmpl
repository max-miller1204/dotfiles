#!/usr/bin/env bash
# Build and activate the single cumulative dotfiles package bundle.
# The workstation bundle is the only supported selection - the pre-activation
# smoke below requires its fnm and uv, and the ownership guard requires its
# attrPath - so it is hardcoded here rather than offered as machine data.
# A source hash for every flake file makes chezmoi rerun this script when the
# package graph or lock changes, without letting routine updates mutate the lock.
# flake hashes: {{ include "nix/flake.nix" | sha256sum }} {{ include "nix/flake.lock" | sha256sum }} {{ include "nix/packages.nix" | sha256sum }} {{ include "nix/bundles.nix" | sha256sum }} {{ include "nix/lsp-smoke.py" | sha256sum }}
{{ template "lib-log.sh" . }}

profile="${XDG_STATE_HOME:-$HOME/.local/state}/nix/profiles/dotfiles"
# Resolve the source path while chezmoi renders the script. Starting a nested
# chezmoi process during apply deadlocks on the parent's persistent state lock.
flake={{ printf "path:%s" (joinPath .chezmoi.sourceDir "nix") | quote }}
bundle="workstation"

# A fresh Determinate install cannot update the parent bootstrap shell, and
# non-interactive chezmoi scripts do not read Fish startup files. Source the
# daemon environment explicitly before using Nix in this process.
for nix_init in \
    /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
    "$HOME/.nix-profile/etc/profile.d/nix.sh"
do
    if [[ -r "$nix_init" ]]; then
        # shellcheck source=/dev/null
        source "$nix_init"
        break
    fi
done
if ! command -v nix >/dev/null 2>&1; then
    echo "Nix bootstrap did not complete before profile activation." >&2
    echo "Resolve the earlier installer error, then run chezmoi apply again." >&2
    exit 1
fi

# jq stays a native package (brew on macOS, apt on Linux), and Homebrew's bin
# directory is not on the stock macOS PATH of a non-interactive apply. Probe the
# brew prefixes directly instead of inheriting an earlier script's shellenv.
if ! command -v jq >/dev/null 2>&1; then
    for brew_bin in /opt/homebrew/bin /usr/local/bin; do
        if [[ -x "$brew_bin/jq" ]]; then
            export PATH="$brew_bin:$PATH"
            break
        fi
    done
fi
if ! command -v jq >/dev/null 2>&1; then
    echo "jq is required for dedicated profile activation." >&2
    echo "Resolve the earlier native package bootstrap error, then run chezmoi apply again." >&2
    exit 1
fi

mkdir -p "$(dirname "$profile")"

# Build and smoke-test without touching the active profile. Under set -e, any
# evaluation, build, or smoke failure leaves the previous generation active.
log "Building the dotfiles $bundle Nix bundle"
out="$(
    nix build "$flake#$bundle" \
        --no-link \
        --print-out-paths
)"
# Validate the built bundle, not the caller's environment: a GOROOT/GOBIN
# exported into this shell would point the go probe at a different toolchain and
# could fail bundle validation (lsp-smoke.py removes NODE_PATH for the same reason).
unset GOROOT GOBIN
for bin in eza bat fd rg fzf gum starship atuin zoxide direnv tmux nvim shellcheck go gopls pyright pyright-langserver tsc tsgo typescript-language-server fnm uv; do
    if [[ ! -x "$out/bin/$bin" ]]; then
        echo "Built bundle is missing executable: $bin" >&2
        exit 1
    fi
    case "$bin" in
        direnv | go | gopls) "$out/bin/$bin" version >/dev/null ;;
        pyright-langserver) ;;
        tmux) "$out/bin/$bin" -V >/dev/null ;;
        *) "$out/bin/$bin" --version >/dev/null ;;
    esac
done
if [[ ! -r "$out/share/nix-direnv/direnvrc" ]]; then
    echo "Built bundle is missing the nix-direnv integration." >&2
    exit 1
fi

if [[ -L "$profile" ]]; then
    profile_json="$(nix profile list --profile "$profile" --json)"
    element_count="$(jq '.elements | length' <<<"$profile_json")"
    if [[ "$element_count" -ne 1 ]]; then
        if [[ "$element_count" -eq 0 ]] \
            && nix profile list --profile "$profile" 2>/dev/null | grep -q 'home-manager-path'
        then
            echo "The dedicated path still contains the retired Home Manager prototype profile." >&2
            echo "Move it aside explicitly before applying this bundle migration:" >&2
            echo "  mv '$profile' '${profile}.home-manager-backup'" >&2
        else
            echo "The dedicated profile must contain exactly one element; found $element_count." >&2
            echo "Refusing to modify a manually changed profile: $profile" >&2
            echo "Move it aside explicitly to rebuild it from this source:" >&2
            echo "  mv '$profile' '${profile}.backup'" >&2
        fi
        exit 1
    fi
    # Identify the element by what it IS, not by where it was installed from: a
    # relocated chezmoi source directory, an apply from a worktree, or a
    # `--source` override changes the flake reference without making the profile
    # foreign or hand-modified.
    element_name="$(jq -r '.elements | to_entries[0].key' <<<"$profile_json")"
    element_attr="$(jq -r '(.elements | to_entries[0].value).attrPath // ""' <<<"$profile_json")"
    element_url="$(jq -r '(.elements | to_entries[0].value).originalUrl // ""' <<<"$profile_json")"
    if [[ "$element_attr" != *.workstation ]]; then
        echo "Dedicated profile element is not the managed workstation bundle." >&2
        echo "Found attrPath '${element_attr:-unknown}' installed from '${element_url:-unknown}'." >&2
        echo "Refusing to modify a manually changed profile: $profile" >&2
        echo "Move it aside explicitly to rebuild it from this source:" >&2
        echo "  mv '$profile' '${profile}.backup'" >&2
        exit 1
    fi
    if [[ "$element_url" == "$flake" ]]; then
        log "Upgrading the dedicated dotfiles Nix profile"
        nix profile upgrade --profile "$profile" --all
    else
        # `nix profile upgrade` re-evaluates the RECORDED flake reference, which
        # may no longer exist. Re-point the managed element at this source.
        log "Re-pointing the dedicated dotfiles Nix profile at $flake"
        nix profile remove --profile "$profile" "$element_name"
        nix profile add --profile "$profile" "$flake#$bundle"
    fi
else
    if [[ -e "$profile" ]]; then
        echo "Dedicated profile path exists but is not a symlink: $profile" >&2
        exit 1
    fi
    log "Creating the dedicated dotfiles Nix profile"
    nix profile add --profile "$profile" "$flake#$bundle"
fi

profile_json="$(nix profile list --profile "$profile" --json)"
if ! jq -e --arg out "$out" \
    '.elements | length == 1 and ([.[] | .storePaths[]?] | index($out) != null)' \
    <<<"$profile_json" >/dev/null
then
    echo "Dedicated profile does not contain exactly the built workstation bundle." >&2
    exit 1
fi

# Make the newly activated tools available to any remaining work in this script.
export PATH="$profile/bin:$PATH"
log "Activated dotfiles-workstation in $profile"
