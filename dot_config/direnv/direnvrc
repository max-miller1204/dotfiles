# Load nix-direnv from the checked-in flake's dedicated profile.
# This avoids an independently downloaded integration and keeps `use flake`
# matched to the nix-direnv package pinned with the global command bundle.
dotfiles_nix_direnv="${XDG_STATE_HOME:-$HOME/.local/state}/nix/profiles/dotfiles/share/nix-direnv/direnvrc"
if [ -r "$dotfiles_nix_direnv" ]; then
  # shellcheck source=/dev/null
  . "$dotfiles_nix_direnv"
fi
