# Essential runtime state and PATH setup must apply to non-interactive Fish too.
# A Fish process launched inside a project flake preserves that devshell first;
# other shells rebuild the deterministic global owner order.
set -l project_environment false
if set -q IN_NIX_SHELL; or set -q DIRENV_DIR
    set project_environment true
end

if test $project_environment = false
    set -gx FNM_DIR $HOME/.local/share/fnm
    set -gx NPM_CONFIG_PREFIX $HOME/.local/share/npm
    set -gx CARGO_HOME $HOME/.cargo
    set -gx RUSTUP_HOME $HOME/.rustup
    set -e RUSTUP_TOOLCHAIN

    {{- if eq .chezmoi.os "darwin" }}
    if test -x /opt/homebrew/bin/brew
        /opt/homebrew/bin/brew shellenv | source
    else if test -x /usr/local/bin/brew
        /usr/local/bin/brew shellenv | source
    end
    {{- end }}
else
    set -q FNM_DIR; or set -gx FNM_DIR $HOME/.local/share/fnm
    set -q NPM_CONFIG_PREFIX; or set -gx NPM_CONFIG_PREFIX $HOME/.local/share/npm
    set -q CARGO_HOME; or set -gx CARGO_HOME $HOME/.cargo
    set -q RUSTUP_HOME; or set -gx RUSTUP_HOME $HOME/.rustup
end

# Track every managed global directory separately so project shells can remove
# startup-time copies and append them only after the devshell paths.
set -l managed_global_path
if set -q FNM_MULTISHELL_PATH; and test -d $FNM_MULTISHELL_PATH/bin
    set -a managed_global_path $FNM_MULTISHELL_PATH/bin
else
    set -a managed_global_path $FNM_DIR/aliases/default/bin
end
set -a managed_global_path $NPM_CONFIG_PREFIX/bin ~/.nix-profile/bin \
    $CARGO_HOME/bin ~/.local/bin ~/.opencode/bin

set -l inherited_path
for dir in $PATH
    if string match -q "$HOME/.local/share/mise/*" -- $dir
        continue
    end
    if test $dir = $HOME/.bun/bin
        continue
    end
    if test $project_environment = true; and contains -- $dir $managed_global_path
        continue
    end
    if not contains -- $dir $inherited_path
        set -a inherited_path $dir
    end
end
set -gx PATH $inherited_path

# Initialize only the selected global Node default. Deliberately omit fnm's
# --use-on-cd hook so project flakes, not runtime version files, own overrides.
set -l fnm_bin $HOME/.nix-profile/bin/fnm
if test $project_environment = false; and test -x $fnm_bin
    $fnm_bin env --shell fish | source
    $fnm_bin use --silent-if-unchanged default >/dev/null 2>&1
end

# Global precedence is fnm Node, the npm prefix, Home Manager, rustup proxies,
# user-local tools, OpenCode, then native paths. Project shells keep their
# inherited devshell entries first and append any missing global fallbacks.
set -l global_path
for dir in $managed_global_path
    if test -d $dir; and not contains -- $dir $global_path
        set -a global_path $dir
    end
end

set -l user_path
if test $project_environment = true
    set user_path $inherited_path
    for dir in $global_path
        if not contains -- $dir $user_path
            set -a user_path $dir
        end
    end
else
    set user_path $global_path
    for dir in $inherited_path
        if not contains -- $dir $user_path
            set -a user_path $dir
        end
    end
end
# A process-local empty value shadows any universal fish_user_paths so Fish
# cannot silently prepend managed global directories after this assignment.
set -g fish_user_paths
set -gx PATH $user_path

if status is-interactive
    # -- Aliases ---------------------------------------------------------

    # Navigation
    alias .. 'cd ..'
    alias ... 'cd ../..'
    alias .... 'cd ../../..'

    # Git
    alias g git
    alias gs 'git status'
    alias gc 'git commit'
    alias gcm 'git commit -m'
    alias gcam 'git commit -a -m'
    alias gcad 'git commit -a --amend'
    alias gl 'git log --oneline'
    alias gp 'git push'

    # Claude Code
    alias c 'claude'
    alias cx 'clear; claude --dangerously-skip-permissions'

    # Docker
    alias d docker

    # Utilities
    alias decompress 'tar -xzf'
    alias t 'tmux attach || tmux new -s Work'
    alias tmux-help 'bat ~/.config/tmux/keybinds.md'

    # -- Environment -----------------------------------------------------

    set -g fish_greeting
    set -gx EDITOR nvim
    set -gx VISUAL nvim
    set -gx BAT_THEME ansi

    # GUI password prompt for sudo -A (useful when no TTY, e.g. Claude Code `!`)
    # macOS: osascript dialog. Linux/GNOME: zenity wrapper (avoids the
    # "Allow inhibiting shortcuts" prompt that gnome-ssh-askpass triggers).
    if test -x ~/.local/bin/mac-askpass
        set -gx SUDO_ASKPASS ~/.local/bin/mac-askpass
        alias sudoa 'sudo -A'
    else if test -x ~/.local/bin/zenity-askpass
        set -gx SUDO_ASKPASS ~/.local/bin/zenity-askpass
        alias sudoa 'sudo -A'
    else if test -x /usr/bin/ssh-askpass
        set -gx SUDO_ASKPASS /usr/bin/ssh-askpass
        alias sudoa 'sudo -A'
    end

    # -- Tool integrations (PATH-resolved, no hardcoded store paths) ----

    if type -q starship
        if test "$TERM" != dumb
            starship init fish | source
        end
    end

    if type -q zoxide
        zoxide init fish | source
    end

    if type -q fzf
        fzf --fish | source
    end

    if type -q atuin
        atuin init fish | source
    end

    # Home Manager's direnv loads a project's .envrc on cd. The chezmoi-owned
    # nix-direnv rc in ~/.config/direnv/direnvrc adds `use flake`, auto-loading
    # a repo's Nix devshell for its LSP and toolchain.
    if type -q direnv
        direnv hook fish | source
    end

    # eza replaces ls if installed. The global PATH order makes Home Manager
    # win over retained rollback copies.
    if type -q eza
        alias ls 'eza -lh --group-directories-first --icons=auto'
        alias la 'ls -a'
        alias ll 'ls -la'
        alias lsa 'eza -lah --group-directories-first --icons=auto'
        alias lt 'eza --tree --level=2 --long --icons --git'
        alias lta 'eza --tree --level=2 --long --icons --git -a'
    else
        alias la 'ls -a'
        alias ll 'ls -la'
    end

    if type -q pfetch
        pfetch
    end

    # Theme (install once via bootstrap step; see README)
    if test -f ~/.config/fish/themes/Catppuccin\ Mocha.theme
        fish_config theme choose "Catppuccin Mocha"
    end

    # Ghostty shell integration (set when running inside ghostty)
    if set -q GHOSTTY_RESOURCES_DIR
        source "$GHOSTTY_RESOURCES_DIR/shell-integration/fish/vendor_conf.d/ghostty-shell-integration.fish"
    end
end
