if status is-interactive
    # -- Aliases ---------------------------------------------------------

    # Navigation
    alias .. 'cd ..'
    alias ... 'cd ../..'
    alias .... 'cd ../../..'

    # Git
    alias g git
    alias gs 'git status'
    alias gc 'git commit'
    alias gcm 'git commit -m'
    alias gcam 'git commit -a -m'
    alias gcad 'git commit -a --amend'
    alias gl 'git log --oneline'
    alias gp 'git push'

    # Claude Code
    alias c 'claude'
    alias cx 'clear; claude --dangerously-skip-permissions'

    # Docker
    alias d docker

    # Utilities
    alias decompress 'tar -xzf'
    alias t 'tmux attach || tmux new -s Work'
    alias tmux-help 'bat ~/.config/tmux/keybinds.md'

    # -- Environment -----------------------------------------------------

    set -g fish_greeting
    set -gx EDITOR nvim
    set -gx VISUAL nvim
    set -gx BAT_THEME ansi

    # GUI password prompt for sudo -A (useful when no TTY, e.g. Claude Code `!`)
    # macOS: osascript dialog. Linux/GNOME: zenity wrapper (avoids the
    # "Allow inhibiting shortcuts" prompt that gnome-ssh-askpass triggers).
    if test -x ~/.local/bin/mac-askpass
        set -gx SUDO_ASKPASS ~/.local/bin/mac-askpass
        alias sudoa 'sudo -A'
    else if test -x ~/.local/bin/zenity-askpass
        set -gx SUDO_ASKPASS ~/.local/bin/zenity-askpass
        alias sudoa 'sudo -A'
    else if test -x /usr/bin/ssh-askpass
        set -gx SUDO_ASKPASS /usr/bin/ssh-askpass
        alias sudoa 'sudo -A'
    end

    # -- PATH ------------------------------------------------------------

    fish_add_path --prepend ~/.local/bin ~/.opencode/bin ~/.atuin/bin

    {{- if eq .chezmoi.os "darwin" }}
    if test -x /opt/homebrew/bin/brew
        /opt/homebrew/bin/brew shellenv | source
    else if test -x /usr/local/bin/brew
        /usr/local/bin/brew shellenv | source
    end
    {{- end }}

    # The checked-in flake owns pinned global CLIs, LSP tooling, fnm, and uv.
    # Pi and Hunk resolve through ~/.local/bin from their stable npm prefixes.
    set -l dotfiles_nix_state "$HOME/.local/state"
    if set -q XDG_STATE_HOME; and test -n "$XDG_STATE_HOME"
        set dotfiles_nix_state "$XDG_STATE_HOME"
    end
    fish_add_path --prepend --move "$dotfiles_nix_state/nix/profiles/dotfiles/bin"

    # Never delete stale mise installations automatically, but retire any shim
    # path inherited from an older shell so migrated commands cannot regain
    # ownership. Match every PATH entry ending in /mise/shims (covers both data
    # homes and the default). mise also honors MISE_DATA_DIR, which can relocate
    # the shim dir outside any /mise/ path, so scrub $MISE_DATA_DIR/shims too
    # without broadening to every */shims (that would strip pyenv/rbenv dirs).
    set -l stale_shim_re '/mise/shims/?$'
    if set -q MISE_DATA_DIR; and test -n "$MISE_DATA_DIR"
        set stale_shim_re "$stale_shim_re"'|^'(string escape --style=regex -- "$MISE_DATA_DIR/shims")'/?$'
    end
    if set -q fish_user_paths
        set -l kept_user_paths (string match -v -r -- $stale_shim_re $fish_user_paths)
        if test (count $kept_user_paths) -ne (count $fish_user_paths)
            # Rewrite in the variable's own scope: a session global would shadow
            # a universal fish_user_paths, silently de-persisting every later
            # interactive fish_add_path call.
            if set -q -g fish_user_paths
                set -g fish_user_paths $kept_user_paths
            else
                set -U fish_user_paths $kept_user_paths
            end
        end
    end
    set -gx PATH (string match -v -r -- $stale_shim_re $PATH)

    # The old mise activation also exported toolchain env that outlives it in
    # any shell nested under a pre-migration session. A stale GOROOT breaks the
    # profile's go outright once the mise dir is gone, and a mise NODE_PATH
    # would shadow typescript-language-server's pinned module. Drop only
    # mise-derived values; user- and project-owned exports pass through.
    for stale_var in GOROOT GOBIN
        if set -q $stale_var; and string match -q '*/mise/installs/*' -- $$stale_var
            set -e $stale_var
        end
    end
    if set -q NODE_PATH; and test -n "$NODE_PATH"
        set -l kept_node_dirs (string match -v '*/mise/installs/*' -- (string split -- : $NODE_PATH))
        if test (count $kept_node_dirs) -eq 0
            set -e NODE_PATH
        else
            set -gx NODE_PATH (string join -- : $kept_node_dirs)
        end
    end
    set -e MISE_SHELL __MISE_DIFF __MISE_SESSION __MISE_ORIG_PATH

    # Mutable runtime paths intentionally sit above the Nix profile. uv-managed
    # project virtual environments and direnv dev shells can still override them.
    set -l uv_data_home "$HOME/.local/share"
    if set -q XDG_DATA_HOME; and test -n "$XDG_DATA_HOME"
        set uv_data_home "$XDG_DATA_HOME"
    end
    set -gx UV_PYTHON_BIN_DIR "$uv_data_home/uv/python-bin"
    fish_add_path --prepend --move "$UV_PYTHON_BIN_DIR"

    set -l cargo_home "$HOME/.cargo"
    if set -q CARGO_HOME; and test -n "$CARGO_HOME"
        set cargo_home "$CARGO_HOME"
    end
    # Drop any exact toolchain override inherited from the old mise activation.
    # Project rust-toolchain files and later direnv hooks still select locally.
    set -e RUSTUP_TOOLCHAIN
    fish_add_path --prepend --move "$cargo_home/bin"

    if not set -q BUN_INSTALL; or test -z "$BUN_INSTALL"
        set -gx BUN_INSTALL "$HOME/.bun"
    end
    fish_add_path --prepend --move "$BUN_INSTALL/bin"

    if type -q fnm
        fnm env --use-on-cd --shell fish | source
    end

    # -- Tool integrations (PATH-resolved, no hardcoded store paths) ----

    if type -q starship
        if test "$TERM" != dumb
            starship init fish | source
        end
    end

    if type -q zoxide
        zoxide init fish | source
    end

    if type -q fzf
        fzf --fish | source
    end

    if type -q atuin
        atuin init fish | source
    end

    # direnv per-directory env loads a project's .envrc on cd. The executable
    # and nix-direnv integration come from the dedicated profile, and `use flake`
    # auto-loads a repo's Nix devshell for its LSP/toolchain.
    if type -q direnv
        direnv hook fish | source
    end

    # eza replaces ls if installed. Probe after adding the dedicated Nix profile
    # so the flake-owned executable wins over any stale native or mise copy.
    if type -q eza
        alias ls 'eza -lh --group-directories-first --icons=auto'
        alias la 'ls -a'
        alias ll 'ls -la'
        alias lsa 'eza -lah --group-directories-first --icons=auto'
        alias lt 'eza --tree --level=2 --long --icons --git'
        alias lta 'eza --tree --level=2 --long --icons --git -a'
    else
        alias la 'ls -a'
        alias ll 'ls -la'
    end

    if type -q pfetch
        pfetch
    end

    # Theme (install once via bootstrap step; see README)
    if test -f ~/.config/fish/themes/Catppuccin\ Mocha.theme
        fish_config theme choose "Catppuccin Mocha"
    end

    # Ghostty shell integration (set when running inside ghostty)
    if set -q GHOSTTY_RESOURCES_DIR
        source "$GHOSTTY_RESOURCES_DIR/shell-integration/fish/vendor_conf.d/ghostty-shell-integration.fish"
    end
end
