{{- /* Derive the LSP server set from the single-source lspLanguages table in
       .chezmoi.toml.tmpl, the same table that drives installation and plugin
       setup, so this upgrade helper cannot drift from either. */ -}}
{{- $rustToolchain := (get . "rustToolchain" | default "stable") -}}
{{- $miseTools := list -}}
{{- $nixLangs := list -}}
{{- $rustupLangs := list -}}
{{- $osLangs := list -}}
{{- range .lspLanguages -}}
{{-   if eq .method "mise" -}}{{- range .miseTools -}}{{- $miseTools = append $miseTools . -}}{{- end -}}{{- end -}}
{{-   if eq .method "nix" -}}{{- $nixLangs = append $nixLangs . -}}{{- end -}}
{{-   if eq .method "rustup" -}}{{- $rustupLangs = append $rustupLangs . -}}{{- end -}}
{{-   if eq .method "os" -}}{{- $osLangs = append $osLangs . -}}{{- end -}}
{{- end -}}
function lsp-upgrade --description 'Upgrade all Claude Code LSP language servers'
    set -l section (set_color --bold cyan)
    set -l reset (set_color normal)

{{- if $miseTools }}
    if command -q mise
        echo "$section==> remaining mise LSP servers$reset"
        mise upgrade {{ $miseTools | join " " }}; or return
    end
{{- end }}
{{- range $rustupLangs }}

    if command -q rustup
        echo "$section==> {{ .rustupComponent }} (rustup {{ $rustToolchain }})$reset"
        rustup update "{{ $rustToolchain }}"; or return
        rustup component add --toolchain "{{ $rustToolchain }}" {{ .rustupComponent }}; or return
    end
{{- end }}
{{- range $nixLangs }}

    echo "$section==> {{ .verifyBin }} is pinned by flake.lock$reset"
{{- end }}
{{- range $osLangs }}

    echo "$section==> {{ .verifyBin }}$reset"
    {{- if eq $.chezmoi.os "darwin" }}
    brew upgrade {{ .brewFormula }}; or return
    {{- else }}
    sudo apt-get install --only-upgrade -y {{ .aptPackage }}; or return
    {{- end }}
{{- end }}
end
