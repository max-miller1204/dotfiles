{{- /* opencode config, chezmoi-managed in full. Unlike Claude (~/.claude.json)
       and Codex (~/.codex/config.toml), which are CLI-owned and rewritten on use
       (so their MCP servers are injected post-apply by run_onchange_after_40/41),
       opencode reads this static file and never rewrites it, so chezmoi renders it
       directly - no sync script. The `mcp` block is derived from the single-source
       mcpServers table in .chezmoidata/mcp.yaml (shared with the Claude/Codex
       staging templates so the three can never drift); we emit only servers tagged
       `opencode`. opencode's local-server schema takes one `command` array (argv),
       so we fold command + args into a single list, prepending {{ .chezmoi.homeDir }}
       to any command_rel since .chezmoidata is static and cannot hold homeDir. */ -}}
{{- $ocServers := list -}}
{{- range .mcpServers -}}
{{-   if has "opencode" .agents -}}{{- $ocServers = append $ocServers . -}}{{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
{{- range $i, $s := $ocServers }}
{{-   $rel := get $s "command_rel" }}
{{-   $cmd := get $s "command" }}
{{-   if and (not $rel) (not $cmd) }}{{ fail (printf "mcp.yaml: server %q has neither command_rel nor command" $s.name) }}{{- end }}
{{-   $first := $cmd }}
{{-   if $rel }}{{ $first = printf "%s/%s" $.chezmoi.homeDir $rel }}{{ end }}
{{-   $argv := concat (list $first) $s.args }}
    {{ toJson $s.name }}: {
      "type": "local",
      "command": {{ toJson $argv }},
      "enabled": true
    }{{ if lt (add1 $i) (len $ocServers) }},{{ end }}
{{- end }}
  }
}
