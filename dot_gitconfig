[user]
	email = maxmiller1204@outlook.com
	name = max

[alias]
	br = branch
	ci = commit
	co = checkout
	st = status
	sync = !git stash push -u -m "wip: pre-sync" && git pull --rebase && git stash pop

[branch]
	sort = -committerdate

[column]
	ui = auto

[commit]
	verbose = true

[credential "https://github.com"]
	helper = !gh auth git-credential

[diff]
	algorithm = histogram
	colorMoved = plain

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rerere]
	autoupdate = true
	enabled = true

[tag]
	sort = -version:refname
